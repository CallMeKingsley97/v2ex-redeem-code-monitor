FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 如果飞书机器人启用了“签名校验”，填写密钥；未启用则留空。
FEISHU_SECRET=

# 轮询间隔，建议不要低于 15 秒，避免给 V2EX 带来不必要压力。
V2EX_POLL_INTERVAL_SECONDS=20

# 首次启动是否推送当前最新列表中已经存在的命中帖子。
NOTIFY_EXISTING_ON_START=false

# 命中阈值，越低越敏感，越高误报越少。
SCORE_THRESHOLD=5

# 本地状态文件。
STATE_FILE=./data/v2ex-monitor-state.json
